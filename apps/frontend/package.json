{
    "name": "@product-reviews/frontend",
    "version": "1.0.0",
    "type": "module",
    "description": "Angular frontend for Product Reviews app",
    "scripts": {
        "ng": "ng",
        "dev": "ng serve --open",
        "start": "ng serve",
        "build": "ng build",
        "build:prod": "ng build --configuration production",
        "test": "ng test --watch=false",
        "test:watch": "ng test",
        "test:cov": "ng test --code-coverage",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui",
        "e2e:debug": "playwright test --debug",
        "lint": "ng lint",
        "format": "prettier --write \"src/**/*.{ts,html,scss,json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,html,scss,json,md}\"",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist node_modules"
    },
    "dependencies": {
        "@angular/animations": "^18.0.0",
        "@angular/common": "^18.0.0",
        "@angular/compiler": "^18.0.0",
        "@angular/core": "^18.0.0",
        "@angular/forms": "^18.0.0",
        "@angular/material": "^18.0.0",
        "@angular/platform-browser": "^18.0.0",
        "@angular/platform-browser-dynamic": "^18.0.0",
        "@angular/router": "^18.0.0",
        "rxjs": "^7.8.1",
        "tslib": "^2.6.2",
        "zone.js": "^0.14.2"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^18.0.0",
        "@angular/cli": "^18.0.0",
        "@angular/compiler-cli": "^18.0.0",
        "@playwright/test": "^1.40.1",
        "@types/jasmine": "^5.1.0",
        "@types/node": "^20.10.6",
        "jasmine-core": "^5.1.1",
        "karma": "^6.4.2",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.1.0",
        "prettier": "^3.1.1",
        "typescript": "^5.3.3"
    }
}